@using Microsoft.AspNetCore.Identity
@using MBET.Core.Entities.Identity
@using MBET.Shared.Resources
@using Microsoft.Extensions.Localization
@inject UserManager<ApplicationUser> UserManager
@inject ISnackbar Snackbar
@inject IStringLocalizer<L> L

<MudDialog>
    <DialogContent>
        <MudText Typo="Typo.body1" Class="mb-4">
            @L["ResettingPasswordFor"] <b>@UserEmail</b>.
            <br />@L["ActionCannotBeUndone"]
        </MudText>
        <MudTextField @bind-Value="_newPassword"
                      Label="@L["NewPassword"]"
                      InputType="InputType.Password"
                      Variant="Variant.Outlined"
                      Required="true" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">@L["Cancel"]</MudButton>
        <MudButton Color="Color.Error" Variant="Variant.Filled" OnClick="ResetPassword">@L["ResetPassword"]</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }

    [Parameter] public string UserId { get; set; }
    [Parameter] public string UserEmail { get; set; }

    private string _newPassword;

    private void Cancel() => MudDialog.Cancel();

    private async Task ResetPassword()
    {
        if (string.IsNullOrEmpty(_newPassword))
        {
            Snackbar.Add(L["PasswordRequired"], Severity.Warning);
            return;
        }

        var user = await UserManager.FindByIdAsync(UserId);
        if (user == null)
        {
            MudDialog.Close(DialogResult.Ok(false));
            return;
        }

        var token = await UserManager.GeneratePasswordResetTokenAsync(user);
        var result = await UserManager.ResetPasswordAsync(user, token, _newPassword);

        if (result.Succeeded)
        {
            Snackbar.Add(L["PasswordResetSuccess"], Severity.Success);
            MudDialog.Close(DialogResult.Ok(true));
        }
        else
        {
            foreach (var error in result.Errors)
            {
                Snackbar.Add(error.Description, Severity.Error);
            }
        }
    }
}