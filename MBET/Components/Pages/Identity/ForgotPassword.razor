@page "/forgot-password"
@using System.ComponentModel.DataAnnotations
@using MBET.Shared.Resources
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<L> L

<PageTitle>Recovery | MBET</PageTitle>

<div class="d-flex justify-center align-center relative" style="min-height: 60vh;">
    <MudContainer MaxWidth="MaxWidth.ExtraSmall" Class="relative z-10">
        <MudPaper Elevation="0" Class="pa-8 rounded-xl glass-panel text-center">
            <MudIcon Icon="@Icons.Material.Filled.MarkEmailRead" Color="Color.Secondary" Size="Size.Large" Class="mb-4" Style="width: 64px; height: 64px;" />

            <MudText Typo="Typo.h5" Class="font-black mb-2">@L["PasswordRecovery"]</MudText>
            <MudText Typo="Typo.body2" Class="mud-text-secondary mb-8">@L["RecoverySubtitle"]</MudText>

            <form action="/account/forgot-password" method="post">
                <MudTextField T="string" Name="Email" Label="@L["EmailAddress"]" Variant="Variant.Outlined" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Email" Class="mb-6" Required="true" />

                <button type="submit" class="mud-button-root mud-button mud-button-filled mud-button-filled-secondary mud-button-filled-size-large mud-width-full py-3 rounded-lg font-bold">
                    <span class="mud-button-label">@L["SendResetLink"]</span>
                </button>
            </form>

            <MudButton Variant="Variant.Text" Color="Color.Inherit" FullWidth="true" Class="mt-4" Href="/login">@L["BackToLogin"]</MudButton>
        </MudPaper>
    </MudContainer>
</div>

<style>
    .glass-panel {
        background: rgba(11, 14, 20, 0.7);
        backdrop-filter: blur(20px);
        border: 1px solid rgba(255,255,255,0.05);
    }
</style>