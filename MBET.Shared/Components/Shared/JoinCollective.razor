@using MudBlazor
@using MBET.Core.Interfaces
@using MBET.Shared.Resources
@using Microsoft.Extensions.Localization

@inject IStringLocalizer<L> L

<section class="py-12 px-6 lg:px-20">
    <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pa-0">
        <MudPaper Class="relative overflow-hidden pa-8 d-flex flex-column align-center text-center rounded-xl"
                  Elevation="0"
                  Style="background: var(--mud-palette-surface); border: 1px solid var(--mud-palette-lines-default);">

            <!-- Ambient Glows (Theme Aware) -->
            <div class="absolute rounded-circle" style="top:-100px; left:-100px; width:300px; height:300px; background:var(--mud-palette-primary); filter:blur(120px); opacity:0.1;"></div>
            <div class="absolute rounded-circle" style="bottom:-100px; right:-100px; width:300px; height:300px; background:var(--mud-palette-secondary); filter:blur(120px); opacity:0.1;"></div>

            <!-- Icon -->
            <div class="d-flex justify-center align-center mb-6"
                 style="width:80px; height:80px; border-radius:24px; background:var(--mud-palette-background); border:1px solid var(--mud-palette-lines-default);">
                <MudIcon Icon="@Icons.Material.Rounded.AutoAwesome" Color="Color.Primary" Size="Size.Large" />
            </div>

            <MudText Typo="Typo.h3" Class="italic font-black mb-2">
                @L["JoinCollectiveTitle"]
            </MudText>

            <MudText Typo="Typo.body1" Class="mud-text-secondary mb-8" Style="max-width: 500px;">
                @L["JoinCollectiveDesc"]
            </MudText>

            <!-- Form -->
            <div class="d-flex gap-3 justify-center flex-wrap w-100" style="max-width: 450px;">
                <MudTextField T="string" Placeholder="@L["EmailAddress"]" Variant="Variant.Outlined" Class="bg-surface rounded-lg" Margin="Margin.Dense" />
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Medium" Class="px-8 rounded-lg font-bold shadow-lg">@L["Subscribe"]</MudButton>
            </div>

            <!-- Divider -->
            <div class="d-flex align-center gap-4 mt-8 w-100 justify-center opacity-60">
                <div style="height:1px; background:var(--mud-palette-lines-default); width: 60px;"></div>
                <MudText Typo="Typo.caption" Class="uppercase font-bold tracking-wider">@L["AlreadyMember"]</MudText>
                <div style="height:1px; background:var(--mud-palette-lines-default); width: 60px;"></div>
            </div>

            <!-- Actions -->
            <div class="d-flex gap-4 mt-6">
                <MudButton Variant="Variant.Outlined" Color="Color.Inherit" Class="px-6 rounded-lg font-bold" Style="border-color: var(--mud-palette-lines-default);" Href="/login">@L["Login"]</MudButton>
                <MudButton Variant="Variant.Filled" Color="Color.Secondary" Class="px-6 rounded-lg font-bold" Href="/register">@L["Join"]</MudButton>
            </div>
        </MudPaper>
    </MudContainer>
</section>