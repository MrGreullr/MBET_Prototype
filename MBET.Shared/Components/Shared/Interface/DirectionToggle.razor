@using MudBlazor

<MudTooltip Text="@(IsRtl ? "Switch to LTR" : "Switch to RTL")">
    <MudIconButton Icon="@(IsRtl? Icons.Material.Filled.FormatTextdirectionLToR : Icons.Material.Filled.FormatTextdirectionRToL)"
                   Color="Color.Inherit"
                   OnClick="ToggleDirection" />
</MudTooltip>

@code {
    [Parameter] public bool IsRtl { get; set; }
    [Parameter] public EventCallback<bool> IsRtlChanged { get; set; }

    private async Task ToggleDirection()
    {
        IsRtl = !IsRtl;
        await IsRtlChanged.InvokeAsync(IsRtl);
    }
}